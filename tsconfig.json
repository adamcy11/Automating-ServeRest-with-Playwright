{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*",
    "pages/**/*",
    "support/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}